        </mxCell>

        <!-- useAdminChat composable -->
        <mxCell id="c-adminChat" value="useAdminChat composable&#xa;(support-chat.gateway.ts)" style="rounded=1;whiteSpace=wrap;fillColor=#0e5a8a;strokeColor=#063a5e;fontColor=#ffffff;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1130" y="288" width="300" height="60" as="geometry"/>
        </mxCell>

        <!-- Arrow: c-chats → c-adminChat -->
        <mxCell id="e-chats-adminChat" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="c-chats" target="c-adminChat" parent="1">
