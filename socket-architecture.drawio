        </mxCell>

        <!-- ═══════════════════════════════════════════ -->
        <!-- TRANSPORT — SOCKET EVENTS (floating labels)-->
        <!-- ═══════════════════════════════════════════ -->

        <!-- Events from useChat → Server -->
        <mxCell id="ev-usechat-down" value="connect({ auth: {token} })&#xa;sendMessage(text)&#xa;query: { conversationId? }" style="text;html=1;align=center;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="403" width="230" height="50" as="geometry"/>
        </mxCell>

        <!-- Events from Server → useChat -->
        <mxCell id="ev-usechat-up" value="history({ conversationId, messages[] })&#xa;newMessage({ conversationId, message })" style="text;html=1;align=center;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="310" y="403" width="280" height="50" as="geometry"/>
        </mxCell>

        <!-- Events from useAdminChat → Server -->
        <mxCell id="ev-adminChat-down" value="connect({ auth: {token} })&#xa;adminReply({ conversationId, text })&#xa;markRead(conversationId)" style="text;html=1;align=center;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1090" y="403" width="270" height="50" as="geometry"/>
        </mxCell>

        <!-- Events from Server → useAdminChat -->
        <mxCell id="ev-adminChat-up" value="newMessage({ conversationId, message })&#xa;unreadCount({ conversationId, count })" style="text;html=1;align=center;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1390" y="403" width="280" height="50" as="geometry"/>
        </mxCell>

        <!-- Arrows: useChat ↔ transport zone -->
        <mxCell id="e-usechat-down" value="Client → Server" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=block;startArrow=none;fontSize=9;" edge="1" source="c-usechat" target="ev-usechat-down" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-usechat-up" value="Server → Client" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;endArrow=block;startArrow=none;startFill=0;fontSize=9;" edge="1" source="ev-usechat-up" target="c-usechat" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrows: useAdminChat ↔ transport zone -->
        <mxCell id="e-adminChat-down" value="Client → Server" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=block;fontSize=9;" edge="1" source="c-adminChat" target="ev-adminChat-down" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-adminChat-up" value="Server → Client" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;endArrow=block;fontSize=9;" edge="1" source="ev-adminChat-up" target="c-adminChat" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════ -->
        <!-- SERVER — SUPPORT CHAT GATEWAY              -->
        <!-- ═══════════════════════════════════════════ -->

        <!-- Gateway outer container -->
        <mxCell id="s-gateway-bg" value="Support-Chat Gateway  (support-chat.gateway.ts)  —  namespace: /support-chat" style="rounded=1;fillColor=#cce5ff;strokeColor=#336699;fontSize=13;fontStyle=1;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="508" width="1060" height="350" as="geometry"/>
        </mxCell>

        <!-- handleConnection label -->
        <mxCell id="s-conn-lbl" value="handleConnection(socket)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=2;fontColor=#003d7a;" vertex="1" parent="1">
          <mxGeometry x="50" y="538" width="260" height="24" as="geometry"/>
        </mxCell>

        <!-- JWT Verify -->
        <mxCell id="s-jwt" value="JWT Verify&#xa;jwtService.verify(token)&#xa;→ { id } | null" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="565" width="190" height="75" as="geometry"/>
        </mxCell>

        <!-- Anonymous path -->
        <mxCell id="s-anon-path" value="Анонимный / Гость&#xa;query.conversationId? → find&#xa;else → createGuestConversation()&#xa;joins conv:{id}" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
