        <!-- useChat composable -->
        <mxCell id="c-usechat" value="useChat composable&#xa;(support-chat.gateway.ts)" style="rounded=1;whiteSpace=wrap;fillColor=#548235;strokeColor=#3a5e22;fontColor=#ffffff;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="288" width="280" height="60" as="geometry"/>
        </mxCell>

        <!-- Arrow: c-widget → c-usechat -->
        <mxCell id="e-widget-usechat" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="c-widget" target="c-usechat" parent="1">
