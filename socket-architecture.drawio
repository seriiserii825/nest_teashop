        </mxCell>
        <mxCell id="e-jwt-admin" value="valid, admin" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="s-jwt" target="s-admin-path" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Room: conv:{id} -->
        <mxCell id="s-room-conv" value="Room: conv:{conversationId}&#xa;(user + admins этой беседы)" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="120" y="670" width="270" height="65" as="geometry"/>
        </mxCell>

        <!-- Room: support:admin -->
        <mxCell id="s-room-admin" value="Room: support:admin&#xa;(все онлайн-администраторы)" style="rounded=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="650" y="670" width="270" height="65" as="geometry"/>
        </mxCell>

        <!-- Arrows: paths → rooms -->
        <mxCell id="e-anon-room" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s-anon-path" target="s-room-conv" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-user-room" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s-user-path" target="s-room-conv" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-admin-room" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s-admin-path" target="s-room-admin" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Events description inside gateway -->
        <mxCell id="s-events-box" value="sendMessage → emit('newMessage') в conv:{id} + support:admin + unreadCount&#xa;adminReply  → emit('newMessage') в conv:{id} + support:admin&#xa;markRead    → markConversationRead(conversationId)&#xa;handleConnection → emit('history', last 100 msgs)" style="rounded=1;fillColor=#eaf5ff;strokeColor=#336699;fontSize=10;align=left;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="50" y="755" width="700" height="82" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════ -->
        <!-- SERVER — REST CONTROLLER                   -->
        <!-- ═══════════════════════════════════════════ -->

        <mxCell id="s-rest-ctrl" value="REST Controller  (support-chat.controller.ts)&#xa;@Admin() @AuthJwt() — только для admin&#xa;&#xa;GET /api/support-chat/conversations&#xa;GET /api/support-chat/conversations/:id/messages" style="rounded=1;whiteSpace=wrap;fillColor=#cce5ff;strokeColor=#336699;fontSize=10;fontStyle=1;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="1110" y="508" width="340" height="130" as="geometry"/>
        </mxCell>

        <!-- Arrow: REST service (client) → REST controller -->
        <mxCell id="e-rest-svc-ctrl" value="HTTP GET" style="edgeStyle=orthogonalEdgeStyle;dashed=1;fontSize=9;" edge="1" source="c-rest-svc" target="s-rest-ctrl" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════ -->
        <!-- SERVER — DEPRECATED BASIC CHAT             -->
        <!-- ═══════════════════════════════════════════ -->

        <mxCell id="s-basic-chat" value="Basic Chat Gateway  [DEPRECATED]&#xa;(chat.gateway.ts)&#xa;&#xa;• Нет комнат — broadcast всем&#xa;• Плоский список сообщений (last 50)&#xa;• Одна таблица messages&#xa;• Без conversationId" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;fontColor=#666666;fontStyle=2;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="1110" y="665" width="340" height="145" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════ -->
        <!-- SERVER — SUPPORT CHAT SERVICE              -->
        <!-- ═══════════════════════════════════════════ -->

        <mxCell id="s-svc" value="SupportChatService  (support-chat.service.ts)&#xa;findOrCreateByUser(user) | createGuestConversation(name?, email?)&#xa;findConversationById(id) | addMessage(conv, text, isFromAdmin)&#xa;getMessages(convId) | markConversationRead(convId) | getUnreadCount(convId) | getAllConversations()" style="rounded=1;whiteSpace=wrap;fillColor=#b3d9f7;strokeColor=#336699;fontSize=10;fontStyle=1;verticalAlign=middle;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="860" width="770" height="72" as="geometry"/>
        </mxCell>

        <!-- Arrow: Gateway → Service -->
        <mxCell id="e-gateway-svc" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s-events-box" target="s-svc" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Arrow: REST Controller → Service -->
        <mxCell id="e-ctrl-svc" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s-rest-ctrl" target="s-svc" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════ -->
        <!-- DB & EXTERNAL                              -->
        <!-- ═══════════════════════════════════════════ -->

        <!-- PostgreSQL -->
        <mxCell id="db-postgres" value="PostgreSQL&#xa;&#xa;• conversations&#xa;  (id, user?, guestName, guestEmail, isAnonymous)&#xa;• conversation_messages&#xa;  (id, conversationId, text, isFromAdmin, isRead)&#xa;• messages  [deprecated]&#xa;  (id, text, authorName, authorEmail, isAnonymous, isRead)" style="shape=cylinder3;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="50" y="960" width="370" height="155" as="geometry"/>
        </mxCell>

        <!-- Telegram -->
        <mxCell id="db-telegram" value="Telegram Bot&#xa;&#xa;Уведомление при каждом&#xa;новом сообщении" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="980" width="220" height="100" as="geometry"/>
        </mxCell>

        <!-- Arrows: Service → DB / Telegram -->
        <mxCell id="e-svc-postgres" value="TypeORM" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="s-svc" target="db-postgres" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-svc-telegram" value="notify" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="s-svc" target="db-telegram" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════ -->
        <!-- TRANSPORT → SERVER / SERVER → TRANSPORT     -->
        <!-- (vertical arrows through transport zone)   -->
        <!-- ═══════════════════════════════════════════ -->

        <!-- Arrow: transport zone → Gateway (visual, floating edge) -->
        <mxCell id="e-transport-gateway" value="WebSocket frames" style="edgeStyle=orthogonalEdgeStyle;entryX=0.3;entryY=0;entryDx=0;entryDy=0;endArrow=block;startArrow=block;startFill=0;fontSize=9;" edge="1" source="ev-usechat-down" target="s-jwt" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-transport-gateway2" value="WebSocket frames" style="edgeStyle=orthogonalEdgeStyle;entryX=0.85;entryY=0;entryDx=0;entryDy=0;endArrow=block;startArrow=block;startFill=0;fontSize=9;" edge="1" source="ev-adminChat-down" target="s-gateway-bg" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1225" y="462"/>
