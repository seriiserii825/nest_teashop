        <!-- sessionStorage -->
        <mxCell id="c-session" value="sessionStorage&#xa;(conversationId — для анонимов)" style="shape=cylinder3;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="293" width="175" height="55" as="geometry"/>
        </mxCell>
        <!-- Arrow: c-usechat ↔ sessionStorage -->
        <mxCell id="e-usechat-session" value="save / restore" style="edgeStyle=orthogonalEdgeStyle;dashed=1;fontSize=9;" edge="1" source="c-usechat" target="c-session" parent="1">
