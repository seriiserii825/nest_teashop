        </mxCell>

        <!-- Auth User path -->
        <mxCell id="s-user-path" value="Авт. пользователь&#xa;findOrCreateByUser(user)&#xa;joins conv:{id}" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="545" width="200" height="85" as="geometry"/>
        </mxCell>

        <!-- Admin path -->
        <mxCell id="s-admin-path" value="Admin (role = ADMIN)&#xa;joins support:admin&#xa;(глобальная комната)" style="rounded=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="755" y="545" width="200" height="85" as="geometry"/>
        </mxCell>

        <!-- Arrows: JWT → paths -->
        <mxCell id="e-jwt-anon" value="нет токена / invalid" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;dashed=1;" edge="1" source="s-jwt" target="s-anon-path" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-jwt-user" value="valid, !admin" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="s-jwt" target="s-user-path" parent="1">
